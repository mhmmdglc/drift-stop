# Bu dosyayı .env olarak kopyala ve değerleri doldur.

# Migration script'leri için (scripts/db-migrate.js, scripts/seed-quotes.js).
# Supabase → Project Settings → Database → Connection string → Session pooler.
SUPABASE_PASSWORD=

# İstemci (Expo app) Supabase bağlantısı. EXPO_PUBLIC_ önekli değişkenler
# derlenen bundle'a gömülür, bu yüzden sadece public/anon değerler olmalı.
EXPO_PUBLIC_SUPABASE_URL=https://ftohdffebzhrthrpeuos.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat — Android public SDK key (RevenueCat dashboard → Project settings
# → Apps → [app] → Public API Key). Play Console entegre edilene kadar Test
# Store key'i ("test_...") kullan; canlıya çıkarken "goog_..." key'e geç.
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
